<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8" />
<title>{{ held.meta.name }} — Heldenkodex</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Cardo:ital,wght@0,400;0,700;1,400&family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<style>
/* ============================================================
   NIVESISCHER STAHL & TINTE — Heldenkodex
   Bildschirm: kalter Codex · Print: klassisches DSA 4.1 Charakterblatt
   ============================================================ */

:root{
  --bg-deep: #0e1418;
  --bg-elev: #1a2638;
  --bg-card: #131c28;
  --bg-inset: #0b1116;

  --ink:      #e8dcc3;
  --ink-mute: #9aa6b4;
  --ink-dim:  #5f6b7a;
  --rule:     #2b3a52;
  --rule-soft:rgba(95,195,228,.18);

  --accent-cold:  #5fc3e4;
  --accent-magic: #6a5acd;
  --accent-blood: #a83246;
  --accent-gold:  #d4a84b;
  --accent-aup:   #9ec6a8;

  --paper:     #ece4d0;
  --paper-ink: #1a1208;
  --paper-rule:#8a7758;

  --display:'Cinzel','Cardo',serif;
  --subhead: 'Cardo','Spectral',serif;
  --body:    'Spectral',Georgia,serif;
  --mono:    'JetBrains Mono','Iosevka',ui-monospace,monospace;

  --r-card:2px;
  --pad:   22px;
  --gap:   18px;
}

*{ box-sizing:border-box; }
html,body{ margin:0; padding:0; }
body{
  font-family: var(--body);
  font-size: 15px;
  line-height: 1.5;
  color: var(--ink);
  background:
    radial-gradient(1200px 800px at 20% -10%, rgba(95,195,228,.06), transparent 60%),
    radial-gradient(900px 700px at 110% 30%, rgba(106,90,205,.07), transparent 60%),
    linear-gradient(180deg, #0a1014 0%, var(--bg-deep) 40%, #080d11 100%);
  background-attachment: fixed;
  min-height: 100vh;
}
a{ color:var(--accent-cold); text-decoration:none; }
a:hover{ text-decoration:underline; text-underline-offset:3px; }

body::before{
  content:"";
  position:fixed; inset:0;
  background-image:
    radial-gradient(circle at 17% 22%, rgba(232,220,195,.04) 0 1px, transparent 1.5px),
    radial-gradient(circle at 71% 64%, rgba(232,220,195,.03) 0 1px, transparent 1.5px),
    radial-gradient(circle at 43% 88%, rgba(232,220,195,.035) 0 1px, transparent 1.5px),
    radial-gradient(circle at 90% 12%, rgba(95,195,228,.05) 0 1px, transparent 1.5px);
  background-size: 380px 380px, 530px 530px, 290px 290px, 410px 410px;
  pointer-events:none;
  mix-blend-mode:screen;
  z-index:0;
}

.codex{
  max-width:1200px;
  margin:0 auto;
  padding:36px 28px 120px;
  position:relative;
  z-index:1;
}
.grid{ display:grid; gap:var(--gap); }
.cols-2{ grid-template-columns:2fr 1fr; }
.cols-3{ grid-template-columns:1fr 1fr 1fr; }
@media(max-width:900px){ .cols-2,.cols-3{ grid-template-columns:1fr; } }

/* ---- Card ---- */
.card{
  position:relative;
  background:linear-gradient(180deg,rgba(26,38,56,.85),rgba(19,28,40,.92));
  border:1px solid var(--rule-soft);
  border-radius:var(--r-card);
  padding:var(--pad);
  box-shadow:
    inset 0 1px 0 rgba(232,220,195,.04),
    inset 0 0 0 1px rgba(95,195,228,.04),
    0 0 0 1px rgba(0,0,0,.5),
    0 12px 30px -16px rgba(0,0,0,.7),
    0 0 60px -30px rgba(95,195,228,.25);
}
.card::before{
  content:"";
  position:absolute; inset:6px;
  border:1px solid rgba(95,195,228,.12);
  border-radius:1px;
  pointer-events:none;
}
.card-title{
  font-family:var(--display);
  font-weight:600;
  font-size:13px;
  letter-spacing:.22em;
  text-transform:uppercase;
  color:var(--ink);
  margin:0 0 14px;
  display:flex;
  align-items:center;
  gap:12px;
}
.card-title::before{
  content:"";
  display:inline-block;
  width:8px; height:8px;
  border:1px solid var(--accent-cold);
  transform:rotate(45deg);
  box-shadow:0 0 8px rgba(95,195,228,.6);
}
.card-title .meta{
  margin-left:auto;
  font-family:var(--mono);
  font-weight:400;
  font-size:11px;
  letter-spacing:.12em;
  color:var(--ink-mute);
}

/* ---- Banner ---- */
.banner{
  position:relative;
  padding:38px 36px 30px;
  margin-bottom:var(--gap);
  background:
    linear-gradient(180deg,rgba(11,17,22,.95),rgba(19,28,40,.85)),
    radial-gradient(ellipse 60% 100% at 50% 0%,rgba(95,195,228,.18),transparent 70%);
  border:1px solid var(--rule-soft);
  border-radius:var(--r-card);
  overflow:hidden;
  box-shadow:inset 0 0 0 1px rgba(95,195,228,.06),0 0 80px -40px rgba(95,195,228,.45);
}
.banner::before{
  content:"";
  position:absolute; inset:10px;
  border:1px solid rgba(212,168,75,.18);
  pointer-events:none;
}
.sparkles{ position:absolute; inset:0; pointer-events:none; overflow:hidden; }
.sparkle{
  position:absolute;
  width:2px; height:2px;
  background:var(--ink);
  border-radius:50%;
  box-shadow:0 0 6px var(--accent-cold),0 0 12px rgba(95,195,228,.6);
  animation:twinkle 4.4s ease-in-out infinite;
}
.sparkle.big{ width:3px; height:3px; box-shadow:0 0 10px var(--accent-cold),0 0 22px rgba(95,195,228,.55); }
.sparkle:nth-child(1){top:14%;left:6%;animation-delay:.0s}
.sparkle:nth-child(2){top:24%;left:17%;animation-delay:1.1s}
.sparkle:nth-child(3){top:60%;left:9%;animation-delay:.7s}
.sparkle:nth-child(4){top:78%;left:23%;animation-delay:2.3s}
.sparkle:nth-child(5){top:20%;left:35%;animation-delay:3.0s}
.sparkle:nth-child(6){top:70%;left:41%;animation-delay:1.5s}
.sparkle:nth-child(7){top:12%;left:62%;animation-delay:.4s}
.sparkle:nth-child(8){top:84%;left:70%;animation-delay:2.7s}
.sparkle:nth-child(9){top:30%;left:80%;animation-delay:1.8s}
.sparkle:nth-child(10){top:56%;left:88%;animation-delay:.9s}
.sparkle:nth-child(11){top:8%;left:92%;animation-delay:3.4s}
.sparkle:nth-child(12){top:64%;left:55%;animation-delay:2.1s}
@keyframes twinkle{
  0%,100%{opacity:0;transform:scale(.6)}
  45%{opacity:1;transform:scale(1.2)}
  55%{opacity:1;transform:scale(1.2)}
}
.banner-inner{
  position:relative;
  display:grid;
  grid-template-columns:auto 1fr auto;
  align-items:center;
  gap:28px;
}
.crest{ width:84px; height:84px; position:relative; display:grid; place-items:center; }
.crest svg{ width:100%; height:100%; filter:drop-shadow(0 0 12px rgba(95,195,228,.4)); }
.title-block .eyebrow{
  font-family:var(--mono);
  font-size:11px;
  letter-spacing:.35em;
  color:var(--accent-cold);
  text-transform:uppercase;
  margin:0 0 6px;
  text-shadow:0 0 12px rgba(95,195,228,.5);
}
.title-block h1{
  font-family:var(--display);
  font-weight:700;
  font-size:44px;
  line-height:1;
  margin:0;
  letter-spacing:.04em;
  color:var(--ink);
  text-shadow:0 0 24px rgba(95,195,228,.18);
}
.title-block h1 .strand{
  background:linear-gradient(180deg,#e8dcc3 0%,#e8dcc3 35%,#ffffff 38%,#ffffff 50%,#e8dcc3 53%,#e8dcc3 100%);
  -webkit-background-clip:text; background-clip:text; color:transparent;
}
.title-block .subline{
  font-family:var(--subhead);
  font-style:italic;
  color:var(--ink-mute);
  font-size:16px;
  margin-top:8px;
  letter-spacing:.02em;
}
.identity-stats{ display:flex; gap:22px; align-items:stretch; }
.istat{ text-align:center; padding:6px 14px; border-left:1px solid var(--rule); min-width:78px; }
.istat:first-child{ border-left:0; }
.istat .num{
  font-family:var(--mono);
  font-weight:700;
  font-size:28px;
  color:var(--accent-gold);
  display:block; line-height:1;
  text-shadow:0 0 12px rgba(212,168,75,.35);
}
.istat .num.cold{ color:var(--accent-cold); text-shadow:0 0 12px rgba(95,195,228,.4); }
.istat .lbl{
  font-family:var(--mono);
  font-size:10px;
  letter-spacing:.25em;
  text-transform:uppercase;
  color:var(--ink-mute);
  margin-top:6px;
  display:block;
}
.banner-meta{
  margin-top:24px; padding-top:18px;
  border-top:1px solid var(--rule);
  display:flex; flex-wrap:wrap; gap:14px 28px;
  font-family:var(--subhead);
  font-size:14px;
  color:var(--ink-mute);
}
.banner-meta strong{ color:var(--ink); font-weight:700; font-family:var(--subhead); }
.banner-meta .sep{ color:var(--ink-dim); }

/* ---- Vitals ---- */
.vitals{ display:flex; flex-direction:column; gap:14px; }
.vital{
  display:grid;
  grid-template-columns:60px 1fr 110px;
  align-items:center;
  gap:14px;
}
.vital .lbl{ font-family:var(--display); font-size:13px; letter-spacing:.14em; color:var(--ink); }
.vital .val{ font-family:var(--mono); font-size:13px; text-align:right; color:var(--ink-mute); }
.vital .val b{ color:var(--ink); font-weight:700; font-size:16px; }
.bar{
  position:relative;
  height:18px;
  background:var(--bg-inset);
  border:1px solid var(--rule);
  border-radius:1px;
  overflow:hidden;
  box-shadow:inset 0 1px 3px rgba(0,0,0,.6);
}
.bar .fill{
  position:absolute; inset:0 auto 0 0;
  background:linear-gradient(90deg,var(--c1),var(--c2));
  box-shadow:inset 0 1px 0 rgba(255,255,255,.18),inset 0 -1px 0 rgba(0,0,0,.35),0 0 18px var(--c2);
}
.bar .fill::after{
  content:""; position:absolute; inset:0;
  background:
    radial-gradient(40% 80% at 20% 50%,rgba(255,255,255,.35),transparent 60%),
    radial-gradient(20% 80% at 70% 50%,rgba(255,255,255,.18),transparent 60%);
  mix-blend-mode:overlay;
}
.bar .ticks{
  position:absolute; inset:0;
  background-image:repeating-linear-gradient(90deg,rgba(232,220,195,.07) 0 1px,transparent 1px 10%);
  pointer-events:none;
}
.bar.lep .fill{ --c1:#5a1c2a; --c2:var(--accent-blood); }
.bar.asp .fill{ --c1:#244c70; --c2:var(--accent-cold); }
.bar.aup .fill{ --c1:#3d5e4a; --c2:var(--accent-aup); }
.minor-stats{
  margin-top:18px; padding-top:14px; border-top:1px dashed var(--rule);
  display:grid; grid-template-columns:repeat(4,1fr); gap:10px;
}
.minor{ text-align:center; }
.minor .v{ font-family:var(--mono); font-weight:700; font-size:22px; color:var(--ink); display:block; line-height:1; }
.minor .k{ font-family:var(--mono); font-size:10px; letter-spacing:.2em; color:var(--ink-mute); text-transform:uppercase; margin-top:4px; display:block; }

/* ---- Hex Attributes ---- */
.attr-card{ max-width:760px; margin:0 auto; }
.hex-grid{
  display:grid;
  grid-template-columns:repeat(8,1fr);
  gap:6px;
  padding:2px 0;
}
@media(max-width:700px){ .hex-grid{ grid-template-columns:repeat(4,1fr); } }
.hex{ position:relative; aspect-ratio:1/1.08; display:grid; place-items:center; text-align:center; }
.hex .shape{
  position:absolute; inset:0;
  clip-path:polygon(50% 2%,95% 27%,95% 75%,50% 100%,5% 75%,5% 27%);
  background:radial-gradient(ellipse at 50% 0%,rgba(95,195,228,.22),transparent 60%),
             linear-gradient(180deg,#1f2c40,#0d141d);
}
.hex .shape::after{
  content:""; position:absolute; inset:3px;
  clip-path:polygon(50% 2%,95% 27%,95% 75%,50% 100%,5% 75%,5% 27%);
  background:linear-gradient(180deg,rgba(95,195,228,.35),rgba(95,195,228,.05) 40%,transparent 70%);
  -webkit-mask:linear-gradient(#000,#000) content-box,linear-gradient(#000,#000);
  -webkit-mask-composite:xor; mask-composite:exclude;
  padding:1px;
}
.hex .inner{ position:relative; z-index:1; padding:6px 4px; }
.hex .abbr{
  font-family:var(--display); font-size:9px; letter-spacing:.2em;
  color:var(--accent-cold); text-transform:uppercase; display:block;
  text-shadow:0 0 6px rgba(95,195,228,.45);
}
.hex .v{ font-family:var(--mono); font-weight:700; font-size:18px; color:var(--ink); display:block; line-height:1.1; margin-top:2px; }
.hex .full{ font-family:var(--subhead); font-size:8px; color:var(--ink-dim); display:block; margin-top:0; letter-spacing:.04em; }
.hex .mod{ position:absolute; top:14%; right:8%; font-family:var(--mono); font-size:8px; color:var(--accent-gold); z-index:2; }

/* ---- Zauber ---- */
.spell{
  display:grid;
  grid-template-columns:1.6fr 1fr auto auto;
  gap:12px;
  align-items:start;
  padding:9px 10px;
  border-bottom:1px solid rgba(95,195,228,.06);
}
.spell:last-child{ border-bottom:0; }
.spell:hover{ background:rgba(95,195,228,.04); }
.spell .name{ font-family:var(--subhead); font-size:14px; color:var(--ink); }
.spell .name .nlink{ color:var(--ink); text-decoration:none; border-bottom:1px dotted rgba(95,195,228,.25); }
.spell .name .nlink:hover{ color:var(--accent-cold); border-bottom-color:var(--accent-cold); }
.spell .name .nlink::after{ content:" ↗"; color:var(--accent-cold); font-size:10px; opacity:.6; }
.spell .name .desc{
  display:block; font-family:var(--subhead); font-style:italic;
  font-size:12px; color:var(--ink-mute); line-height:1.4; margin-top:3px;
}
.spell .name .haus{ color:var(--accent-gold); font-family:var(--mono); font-size:12px; margin-left:6px; }
.spell .merk,.spell .probe{ padding-top:2px; }
.spell .merk{ font-family:var(--mono); font-size:10px; color:var(--ink-mute); letter-spacing:.04em; }
.spell .probe{ font-family:var(--mono); font-size:11px; color:var(--ink-dim); letter-spacing:.04em; }
.zfw-num{
  display:inline-block; font-family:var(--mono); font-weight:700;
  font-size:13px; color:var(--ink); min-width:22px; text-align:right;
}
.legend-row{
  margin-top:10px; padding-top:10px; border-top:1px dashed var(--rule);
  font-family:var(--mono); font-size:10px; color:var(--ink-mute); letter-spacing:.04em;
  display:flex; flex-wrap:wrap; gap:14px;
}
.legend-row span b{ color:var(--accent-gold); }

/* ---- Talent List ---- */
.talent-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:18px 28px; }
@media(max-width:700px){ .talent-grid{ grid-template-columns:1fr; } }
.talent-grp h4{
  font-family:var(--display); font-size:11px; letter-spacing:.22em; text-transform:uppercase;
  color:var(--accent-cold); margin:0 0 10px; padding-bottom:6px;
  border-bottom:1px solid var(--rule-soft);
  display:flex; align-items:center; gap:8px;
}
.talent-grp h4 .skt{ margin-left:auto; font-family:var(--mono); font-size:10px; color:var(--ink-mute); letter-spacing:.15em; }
.talent-row{
  display:grid;
  grid-template-columns:1fr auto auto;
  gap:10px;
  align-items:center;
  padding:3px 0;
  font-size:13px;
}
.talent-row .t-name{ color:var(--ink); font-family:var(--subhead); }
.talent-row .t-probe{ font-family:var(--mono); font-size:11px; color:var(--ink-mute); letter-spacing:.03em; font-weight:600; }
.talent-row .t-zfw{ font-family:var(--mono); font-weight:700; color:var(--ink); min-width:28px; text-align:right; }
.talent-row.high .t-zfw{ color:var(--accent-gold); }
.talent-row.high .t-name{ color:#f3e8c8; font-weight:700; }
.talent-row.zero .t-name,.talent-row.zero .t-zfw{ color:var(--ink-dim); }

/* ---- Equipment ---- */
.equip-stat{
  display:grid; grid-template-columns:1fr auto;
  align-items:baseline;
  border-bottom:1px dashed var(--rule);
  padding:6px 0;
}
.equip-stat:last-child{ border-bottom:0; }
.equip-stat .k{ font-family:var(--subhead); color:var(--ink-mute); font-size:13px; }
.equip-stat .v{ font-family:var(--mono); color:var(--ink); font-size:14px; }
.weapon-card{
  background:var(--bg-inset); border:1px solid var(--rule-soft);
  padding:14px; margin-bottom:14px;
}
.weapon-card .w-name{
  font-family:var(--display); font-size:14px; letter-spacing:.12em;
  color:var(--accent-gold); text-transform:uppercase; margin-bottom:8px;
}
.weapon-grid{
  display:grid; grid-template-columns:repeat(6,1fr);
  gap:6px; font-family:var(--mono); font-size:11px;
}
.weapon-grid > div{
  background:rgba(95,195,228,.05); padding:6px 4px; text-align:center;
  border:1px solid var(--rule-soft);
}
.weapon-grid .k{ display:block; font-size:9px; color:var(--ink-mute); letter-spacing:.15em; text-transform:uppercase; margin-bottom:2px; }
.weapon-grid .v{ color:var(--ink); font-weight:700; font-size:13px; }
.inv-list{ list-style:none; padding:0; margin:0; }
.inv-list li{
  padding:5px 0; border-bottom:1px dotted var(--rule);
  display:grid; grid-template-columns:auto 1fr auto; gap:12px;
  font-size:13px; font-family:var(--subhead); color:var(--ink);
}
.inv-list li::before{ content:"◇"; color:var(--accent-cold); font-size:9px; }
.inv-list li .qty{ font-family:var(--mono); color:var(--ink-mute); font-size:12px; }

/* ---- SF List ---- */
.sf-list{ list-style:none; padding:0; margin:0; }
.sf-list li{
  padding:9px 0; display:grid; grid-template-columns:14px 1fr;
  gap:10px; border-bottom:1px dotted var(--rule); font-size:13px; align-items:start;
}
.sf-list li:last-child{ border-bottom:0; }
.sf-list li .ico{ color:var(--accent-magic); text-shadow:0 0 6px rgba(106,90,205,.6); font-family:var(--mono); padding-top:2px; }
.sf-list.general li .ico{ color:var(--accent-gold); text-shadow:0 0 6px rgba(212,168,75,.5); }
.sf-list li .sf-name{
  font-family:var(--subhead); color:var(--ink);
  display:inline-flex; align-items:baseline; gap:6px; flex-wrap:wrap;
}
.sf-list li .sf-name a{
  color:var(--ink); text-decoration:none;
  border-bottom:1px dotted rgba(95,195,228,.25);
}
.sf-list li .sf-name a:hover{ color:var(--accent-cold); border-bottom-color:var(--accent-cold); }
.sf-list li .sf-name a::after{ content:" ↗"; color:var(--accent-cold); font-size:10px; opacity:.6; }
.sf-list li .sf-desc{ display:block; color:var(--ink-mute); font-size:12px; margin-top:3px; font-style:italic; line-height:1.4; }

/* ---- Campaign ---- */
.campaign{
  padding:18px;
  background:linear-gradient(135deg,rgba(106,90,205,.10),rgba(95,195,228,.04));
  border:1px solid rgba(106,90,205,.25);
}
.campaign .c-head{ display:flex; align-items:baseline; gap:12px; margin-bottom:8px; }
.campaign h3{ font-family:var(--display); font-size:22px; margin:0; letter-spacing:.04em; color:var(--ink); }
.status{
  display:inline-flex; align-items:center; gap:6px;
  font-family:var(--mono); font-size:10px; letter-spacing:.2em;
  color:var(--accent-gold); text-transform:uppercase;
}
.status .dot-s{
  width:10px; height:10px; border-radius:50%;
  background:var(--accent-gold); box-shadow:0 0 10px var(--accent-gold);
  animation:pulse 2.4s ease-in-out infinite;
}
@keyframes pulse{ 50%{ opacity:.4; transform:scale(.85); } }
.campaign p{ color:var(--ink-mute); margin:6px 0 0; font-style:italic; }
.c-meta{
  margin-top:14px; display:flex; gap:22px;
  font-family:var(--mono); font-size:11px; color:var(--ink-mute); letter-spacing:.12em;
}
.c-meta b{ color:var(--ink); }

/* ---- Activity Feed ---- */
.feed{ list-style:none; margin:0; padding:0; position:relative; }
.feed::before{
  content:""; position:absolute; top:0; bottom:0; left:6px;
  width:1px; background:var(--rule);
}
.feed li{
  position:relative; padding:8px 0 12px 26px;
  font-size:13px; color:var(--ink-mute); font-family:var(--subhead);
}
.feed li::before{
  content:""; position:absolute; left:2px; top:12px;
  width:9px; height:9px; border-radius:50%;
  background:var(--bg-deep); border:1px solid var(--accent-cold);
  box-shadow:0 0 6px rgba(95,195,228,.5);
}
.feed li .when{ font-family:var(--mono); font-size:10px; color:var(--accent-cold); letter-spacing:.15em; display:block; margin-bottom:2px; }
.feed li .what{ color:var(--ink); }

/* ---- Vor/Nachteile ---- */
.vn-grid{ display:grid; grid-template-columns:1fr 1fr; gap:20px; }
@media(max-width:700px){ .vn-grid{ grid-template-columns:1fr; } }
.vn-grp h4{
  font-family:var(--display); font-size:11px; letter-spacing:.22em; text-transform:uppercase;
  margin:0 0 8px; padding-bottom:6px; border-bottom:1px solid var(--rule-soft);
}
.vn-grp.pos h4{ color:var(--accent-cold); }
.vn-grp.neg h4{ color:var(--accent-blood); }
.vn-grp.bad h4{ color:var(--accent-gold); }
.vn-list{ list-style:none; padding:0; margin:0; }
.vn-list li{
  padding:5px 0; border-bottom:1px dotted var(--rule);
  font-size:13px; font-family:var(--subhead);
  display:grid; grid-template-columns:1fr auto; gap:8px;
}
.vn-list li:last-child{ border-bottom:0; }
.vn-list li b{ color:var(--ink); font-weight:700; }
.vn-list li .stufe{ font-family:var(--mono); font-size:11px; color:var(--accent-gold); }
.vn-list li small{ display:block; color:var(--ink-mute); font-size:11px; font-style:italic; margin-top:2px; }

/* ---- Print Button ---- */
.print-btn{
  position:fixed; bottom:28px; right:28px;
  padding:14px 22px;
  background:linear-gradient(180deg,#1f3a55,#102232);
  color:var(--ink); font-family:var(--display); font-size:12px;
  letter-spacing:.22em; text-transform:uppercase;
  border:1px solid var(--accent-cold); border-radius:1px; cursor:pointer;
  box-shadow:0 0 0 1px rgba(0,0,0,.5),0 8px 20px -8px rgba(0,0,0,.7),0 0 30px -8px rgba(95,195,228,.5);
  transition:transform .15s ease,box-shadow .15s ease; z-index:100;
}
.print-btn:hover{
  transform:translateY(-1px);
  box-shadow:0 0 0 1px rgba(0,0,0,.5),0 12px 28px -8px rgba(0,0,0,.7),0 0 50px -6px rgba(95,195,228,.7);
}
.print-btn::before{ content:"❖  "; color:var(--accent-cold); }

/* ---- Section Header ---- */
.sec-head{ margin:30px 0 14px; display:flex; align-items:baseline; gap:16px; }
.sec-head h2{
  font-family:var(--display); font-weight:600; font-size:14px;
  letter-spacing:.35em; text-transform:uppercase; color:var(--ink-mute); margin:0;
}
.sec-head .rule{ flex:1; height:1px; background:linear-gradient(90deg,var(--rule),transparent); }

/* ---- Story (Vorgeschichte) ---- */
.story{ font-size:14px; line-height:1.65; color:var(--ink); }
.story p{ margin:0 0 12px; }
.story p:first-of-type::first-letter{
  font-family:var(--display); font-size:54px; float:left; line-height:.85;
  margin:4px 10px 0 0; color:var(--accent-cold);
  text-shadow:0 0 16px rgba(95,195,228,.45);
}

/* ---- Visibility ---- */
.print-only{ display:none; }
@media print{
  .print-only{ display:block; }
  .screen-only{ display:none !important; }
}

/* ============================================================
   PRINT — DSA 4.1 Klassisches Charakterblatt
   ============================================================ */
@media print{
  @page{ size:A4; margin:14mm 12mm; }
  body{ background:var(--paper) !important; color:var(--paper-ink); font-family:'Cardo','Spectral',serif; font-size:10pt; line-height:1.35; }
  body::before,.sparkles,.print-btn{ display:none !important; }
  .codex{ max-width:100%; padding:0; }
  .page{ page-break-after:always; }
  .page:last-child{ page-break-after:auto; }
  .card,.banner,.campaign{
    background:transparent !important; border:1px solid var(--paper-rule) !important;
    box-shadow:none !important; padding:10px 12px !important; margin-bottom:8px;
    color:var(--paper-ink) !important; border-radius:0;
  }
  .card::before,.banner::before{ display:none !important; }
  .card-title,.sec-head h2,.talent-grp h4,.vn-grp h4,.crest svg,
  .istat .lbl,.minor .k,.hex .abbr,.talent-row .t-probe,
  .spell .merk,.spell .probe,.feed li .when,.c-meta{
    color:var(--paper-ink) !important; text-shadow:none !important;
  }
  .card-title::before{ border-color:var(--paper-ink); box-shadow:none; }
  .sec-head .rule{ background:linear-gradient(90deg,var(--paper-rule),transparent); }
  .sec-head{ margin:14px 0 6px; }
  .sec-head h2{ font-size:9pt; }
  .banner{
    background:transparent !important; text-align:center;
    border-bottom:2px solid var(--paper-ink) !important;
    border-top:0 !important; border-left:0 !important; border-right:0 !important;
    padding:0 0 8px !important; margin-bottom:12px !important;
  }
  .banner-inner{ grid-template-columns:1fr; gap:4px; }
  .title-block h1{ font-family:'Cinzel',serif; color:var(--paper-ink) !important; font-size:22pt; text-shadow:none !important; }
  .title-block h1 .strand{ background:none; color:var(--paper-ink) !important; -webkit-text-fill-color:var(--paper-ink); }
  .title-block .eyebrow{ color:var(--paper-ink) !important; text-shadow:none !important; }
  .title-block .subline{ color:#4a3a20; }
  .crest{ display:none; }
  .identity-stats{ justify-content:center; }
  .istat{ border-color:var(--paper-rule); }
  .istat .num{ color:var(--paper-ink) !important; text-shadow:none !important; font-size:16pt; }
  .banner-meta{ justify-content:center; border-color:var(--paper-ink); color:var(--paper-ink) !important; font-size:9pt; }
  .banner-meta strong{ color:var(--paper-ink) !important; }
  .bar{ background:transparent !important; border:0 !important; border-bottom:1px solid var(--paper-ink) !important; height:12pt !important; box-shadow:none !important; }
  .bar .fill,.bar .ticks{ display:none !important; }
  .vital .lbl,.vital .val,.vital .val b{ color:var(--paper-ink) !important; }
  .vital .val{ font-size:10pt; }
  .minor .v,.minor .k,.hex .v,.hex .full,.hex .mod{ color:var(--paper-ink) !important; text-shadow:none !important; }
  .hex .shape{ clip-path:none !important; background:transparent !important; border:1.5px solid var(--paper-ink); }
  .hex .shape::after{ display:none !important; }
  .hex .abbr{ color:var(--paper-ink) !important; }
  .talent-grp h4,.vn-grp h4{ color:var(--paper-ink) !important; border-color:var(--paper-ink) !important; }
  .talent-row,.spell,.vn-list li,.sf-list li,.inv-list li{ border-color:var(--paper-rule) !important; }
  .talent-row .t-name,.talent-row .t-zfw,
  .spell .name,.spell .merk,.spell .probe,
  .vn-list li b,.vn-list li small,
  .sf-list li .sf-name,.sf-list li .sf-desc,
  .inv-list li,.inv-list li .qty{ color:var(--paper-ink) !important; }
  .talent-row.high .t-name,.talent-row.high .t-zfw{ font-weight:700; }
  .talent-row.zero .t-name,.talent-row.zero .t-zfw{ color:#7a6a4a !important; }
  .weapon-card{ background:transparent !important; border-color:var(--paper-ink) !important; }
  .weapon-card .w-name{ color:var(--paper-ink) !important; font-size:10pt; }
  .weapon-grid > div{ background:transparent !important; border-color:var(--paper-ink) !important; }
  .weapon-grid .k,.weapon-grid .v{ color:var(--paper-ink) !important; }
  .sf-list li .ico{ color:var(--paper-ink) !important; text-shadow:none !important; }
  .campaign{ background:transparent !important; border:1px solid var(--paper-ink) !important; }
  .campaign h3,.status,.status .dot-s,.c-meta b,.c-meta{ color:var(--paper-ink) !important; }
  .status .dot-s{ background:var(--paper-ink) !important; box-shadow:none !important; animation:none; }
  .feed::before{ background:var(--paper-rule); }
  .feed li::before{ background:var(--paper) !important; border-color:var(--paper-ink) !important; box-shadow:none; }
  .feed li,.feed li .when,.feed li .what{ color:var(--paper-ink) !important; }
  .vn-grp.pos h4,.vn-grp.neg h4,.vn-grp.bad h4{ color:var(--paper-ink) !important; }
  .vn-list li .stufe{ color:var(--paper-ink) !important; font-weight:700; }
  .story p{ font-size:10pt; line-height:1.5; color:var(--paper-ink); text-indent:0; margin:0 0 8px; }
  .story p + p{ text-indent:14pt; }
  .story p:first-of-type::first-letter{ font-family:'Cinzel',serif; font-size:32pt; float:left; line-height:.9; margin:2pt 6pt 0 0; color:var(--paper-ink); }
}
</style>
</head>
<body>
<div class="codex">

{% set name_parts = held.meta.name.split(' ') %}
{% set first_name = name_parts[:-1] | join(' ') %}
{% set last_name = name_parts[-1] %}

<!-- ============================================================
     IDENTITY BANNER (Seite 1 im Print)
     ============================================================ -->
<header class="banner page">
  <div class="sparkles screen-only">
    <span class="sparkle"></span><span class="sparkle big"></span><span class="sparkle"></span>
    <span class="sparkle"></span><span class="sparkle"></span><span class="sparkle big"></span>
    <span class="sparkle"></span><span class="sparkle"></span><span class="sparkle"></span>
    <span class="sparkle big"></span><span class="sparkle"></span><span class="sparkle"></span>
  </div>

  <div class="banner-inner">
    <div class="crest">
      <svg viewBox="0 0 100 100" fill="none" stroke="#5fc3e4" stroke-width="1.2">
        <polygon points="50,4 92,28 92,72 50,96 8,72 8,28" />
        <polygon points="50,12 84,32 84,68 50,88 16,68 16,32" stroke-opacity=".5" />
        <line x1="50" y1="22" x2="50" y2="78" stroke-width="2"/>
        <circle cx="50" cy="50" r="9" stroke="#d4a84b" />
        <circle cx="50" cy="50" r="3" fill="#d4a84b" stroke="none"/>
        <line x1="50" y1="50" x2="30" y2="30" />
        <line x1="50" y1="50" x2="70" y2="30" />
        <line x1="50" y1="50" x2="30" y2="70" />
        <line x1="50" y1="50" x2="70" y2="70" />
        <line x1="50" y1="50" x2="50" y2="32" stroke="#e8dcc3" stroke-opacity=".6"/>
        <line x1="50" y1="50" x2="50" y2="68" stroke="#e8dcc3" stroke-opacity=".6"/>
      </svg>
    </div>

    <div class="title-block">
      <p class="eyebrow">{% if held.meta.kolleg %}{{ held.meta.kolleg }}{% else %}{{ held.meta.tradition }}{% endif %} · {{ held.meta.tradition }}</p>
      <h1>{{ first_name }} <span class="strand">{{ last_name }}</span></h1>
      {% if held.meta.wahrer_name %}<div class="subline">„{{ held.meta.wahrer_name }}" — {{ held.meta.wahrer_name_bedeutung }}</div>{% endif %}
    </div>

    <div class="identity-stats">
      <div class="istat">
        <span class="num">{{ held.meta.stufe | roman }}</span>
        <span class="lbl">Stufe</span>
      </div>
      <div class="istat">
        <span class="num">{{ held.meta.ap_gesamt | format_ap }}</span>
        <span class="lbl">AP gesamt</span>
      </div>
      <div class="istat">
        <span class="num cold">{{ held.meta.ap_verfuegbar }}</span>
        <span class="lbl">AP frei</span>
      </div>
    </div>
  </div>

  <div class="banner-meta">
    <span><strong>{{ held.meta.rasse }}</strong></span><span class="sep">·</span>
    <span><strong>{{ held.meta.kultur }}</strong></span><span class="sep">·</span>
    <span><strong>{{ held.meta.profession_short }}</strong></span><span class="sep">·</span>
    <span>Tradition <strong>{{ held.meta.tradition }}</strong></span>
    {% if held.meta.stigma %}<span class="sep">·</span><span>Stigma <strong>{{ held.meta.stigma }}</strong></span>{% endif %}
  </div>
</header>

<!-- ============================================================
     VITALS + KAMPFWERTE
     ============================================================ -->
{% set le = held.basiswerte.get('LE', {}) %}
{% set ae = held.basiswerte.get('AE', {}) %}
{% set au = held.basiswerte.get('AU', {}) %}
{% set mr = held.basiswerte.get('MR', {}) %}
{% set ini = held.basiswerte.get('INI', {}) %}
{% set at_bw = held.basiswerte.get('AT', {}) %}
{% set pa_bw = held.basiswerte.get('PA', {}) %}
{% set gs = held.eigenschaften.get('GS', {}) %}
{% set so = held.eigenschaften.get('SO', {}) %}

<div class="grid cols-2">
  <section class="card">
    <h3 class="card-title">Vitalia <span class="meta">Aktuell / Maximum</span></h3>
    <div class="vitals">
      <div class="vital">
        <span class="lbl">LeP</span>
        <div class="bar lep"><span class="fill" style="width:100%"></span><span class="ticks"></span></div>
        <span class="val"><b>{{ le.aktuell }}</b> / {{ le.aktuell }}</span>
      </div>
      <div class="vital">
        <span class="lbl">AsP</span>
        <div class="bar asp"><span class="fill" style="width:100%"></span><span class="ticks"></span></div>
        <span class="val"><b>{{ ae.aktuell }}</b> / {{ ae.aktuell }}</span>
      </div>
      <div class="vital">
        <span class="lbl">AuP</span>
        <div class="bar aup"><span class="fill" style="width:100%"></span><span class="ticks"></span></div>
        <span class="val"><b>{{ au.aktuell }}</b> / {{ au.aktuell }}</span>
      </div>
    </div>
    <div class="minor-stats">
      <div class="minor"><span class="v">{{ mr.aktuell }}</span><span class="k">MR</span></div>
      <div class="minor"><span class="v">{{ ini.aktuell }}</span><span class="k">INI</span></div>
      <div class="minor"><span class="v">{{ gs.aktuell }}</span><span class="k">GS</span></div>
      <div class="minor"><span class="v">{{ so.aktuell }}</span><span class="k">SO</span></div>
    </div>
  </section>

  <section class="card">
    <h3 class="card-title">Kampfwerte <span class="meta">Basis</span></h3>
    <div class="minor-stats" style="margin-top:0;border-top:0;padding-top:0;grid-template-columns:repeat(3,1fr);gap:14px">
      <div class="minor"><span class="v" style="color:var(--accent-gold)">{{ at_bw.aktuell }}</span><span class="k">AT-Basis</span></div>
      <div class="minor"><span class="v" style="color:var(--accent-gold)">{{ pa_bw.aktuell }}</span><span class="k">PA-Basis</span></div>
      <div class="minor"><span class="v" style="color:var(--accent-gold)">{{ held.basiswerte.get('FK', {}).aktuell }}</span><span class="k">FK-Basis</span></div>
    </div>
    {% if held.ausruestung.waffen %}
    <div style="margin-top:18px;padding-top:14px;border-top:1px dashed var(--rule)">
      {% set w = held.ausruestung.waffen[0] %}
      <div class="weapon-card">
        <div class="w-name">{{ w.name }}</div>
        <div class="weapon-grid">
          <div><span class="k">DK</span><span class="v">{{ w.dk }}</span></div>
          <div><span class="k">TP</span><span class="v">{{ w.tp }}</span></div>
          <div><span class="k">AT</span><span class="v">{{ w.at }}</span></div>
          <div><span class="k">PA</span><span class="v">{{ w.pa if w.pa else '—' }}</span></div>
          <div><span class="k">INI</span><span class="v">{{ w.ini if w.ini else '+0' }}</span></div>
          <div><span class="k">BF</span><span class="v">{{ w.bf if w.bf else '—' }}</span></div>
        </div>
      </div>
      {% set kampf = held.talente.get('Kampftechniken', []) %}
      {% for kt in kampf %}{% if kt.name in w.name or w.name in kt.name or 'Stab' in kt.name and 'Stab' in w.name %}
      <div style="font-family:var(--mono);font-size:10px;color:var(--ink-mute);letter-spacing:.06em;line-height:1.5">
        Kampftechnik <b style="color:var(--ink)">{{ kt.name }}</b> · TaW {{ kt.taw }}{% if kt.stk %} · Stk {{ kt.stk }}{% endif %}
      </div>
      {% endif %}{% endfor %}
    </div>
    {% endif %}
  </section>
</div>

<!-- Eigenschaften -->
<div class="sec-head"><h2>Eigenschaften</h2><span class="rule"></span></div>
<section class="card attr-card">
  <div class="hex-grid">
    {% set eig_order = ['MU','KL','IN','CH','FF','GE','KO','KK'] %}
    {% for abbr in eig_order %}
    {% set e = held.eigenschaften.get(abbr, {}) %}
    <div class="hex">
      <div class="shape"></div>
      {% if e.get('mod', 0) != 0 %}<span class="mod">{% if e.mod > 0 %}+{% endif %}{{ e.mod }}</span>{% endif %}
      <div class="inner">
        <span class="abbr">{{ abbr }}</span>
        <span class="v">{{ e.get('aktuell', '?') }}</span>
        <span class="full">{{ e.get('full', abbr) }}</span>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- Vor- & Nachteile -->
<div class="sec-head"><h2>Vor- &amp; Nachteile · Schlechte Eigenschaften</h2><span class="rule"></span></div>
<section class="card">
  <div class="vn-grid">
    <div class="vn-grp pos">
      <h4>Vorteile</h4>
      <ul class="vn-list">
        {% for v in held.vor_nachteile.vorteile %}
        <li>
          <span><b>{{ v.name }}</b>{% if v.anmerkung %}<small>{{ v.anmerkung }}</small>{% endif %}</span>
          <span class="stufe">{{ v.stufe }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
    <div class="vn-grp neg">
      <h4>Nachteile</h4>
      <ul class="vn-list">
        {% for n in held.vor_nachteile.nachteile %}
        <li>
          <span><b>{{ n.name }}</b>{% if n.anmerkung %}<small>{{ n.anmerkung }}</small>{% endif %}</span>
          <span class="stufe">{{ n.stufe }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% if held.vor_nachteile.schlecht %}
    <div class="vn-grp bad" style="grid-column:1/-1">
      <h4>Schlechte Eigenschaften</h4>
      <ul class="vn-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:4px 18px">
        {% for s in held.vor_nachteile.schlecht %}
        <li>
          <span><b>{{ s.name }}</b>{% if s.konsequenz %}<small>{{ s.konsequenz[:60] }}{% if s.konsequenz|length > 60 %}…{% endif %}</small>{% endif %}</span>
          <span class="stufe">{{ s.stufe }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
</section>

<!-- ============================================================
     SEITE 2 — TALENTE
     ============================================================ -->
<div class="sec-head page"><h2>Talente</h2><span class="rule"></span></div>
<section class="card">
  <div class="talent-grid">

    {% for grp_name, grp_rows in held.talente.items() %}
    {% set is_kampf = 'Kampftechnik' in grp_name %}
    <div class="talent-grp">
      <h4>
        {{ grp_name | replace(' (SKT D)', '') | replace(' (SKT B)', '') | replace(' (SKT A)', '') }}
        <span class="skt">
          {%- if is_kampf %}AT / PA · TaW
          {%- elif 'SKT D' in grp_name %}SKT D
          {%- elif 'SKT B' in grp_name %}SKT B
          {%- elif 'SKT A' in grp_name %}SKT A
          {%- endif -%}
        </span>
      </h4>
      {% for row in grp_rows %}
      {% set cls = 'high' if row.taw >= 5 else ('zero' if row.taw == 0 else '') %}
      <div class="talent-row {{ cls }}">
        <span class="t-name">{{ row.name }}</span>
        <span class="t-probe">
          {%- if is_kampf %}{{ row.at }} / {% if row.pa is not none %}{{ row.pa }}{% else %}—{% endif %}
          {%- else %}{{ row.probe }}
          {%- endif -%}
        </span>
        <span class="t-zfw">{{ row.taw }}</span>
      </div>
      {% endfor %}
    </div>
    {% endfor %}

  </div>
</section>

<!-- ============================================================
     SEITE 3 — ZAUBER + RITUALE + SONDERFERTIGKEITEN
     ============================================================ -->
<div class="sec-head page"><h2>Zauberliste <span style="color:var(--ink-dim);font-size:10px;letter-spacing:.2em">· Repräsentation Mag · × = Hauszauber</span></h2><span class="rule"></span></div>
<section class="card">

  <div class="spell" style="border-bottom:1px solid var(--rule);font-family:var(--mono);font-size:10px;letter-spacing:.18em;color:var(--ink-mute);text-transform:uppercase">
    <span>Zauber</span><span>Merkmale</span><span>Probe</span><span>ZfW</span>
  </div>

  {% for z in held.zauber %}
  {% set url = '../' + z.wiki_path + '.md' if z.wiki_path else '' %}
  <div class="spell">
    <span class="name">
      {% if url %}<a class="nlink" href="{{ url }}">{{ z.name }}</a>{% else %}{{ z.name }}{% endif %}
      {% if z.haus %}<span class="haus">×</span>{% endif %}
      {% if z.desc %}<span class="desc">{{ z.desc }}</span>{% endif %}
    </span>
    <span class="merk">{{ z.merkmale }}</span>
    <span class="probe">{{ z.probe }}</span>
    <span class="zfw-num">{{ z.zfw }}</span>
  </div>
  {% endfor %}

  <div class="legend-row">
    <span><b>Anti</b> Anti-Magie</span>
    <span><b>Einfl</b> Einfluss</span>
    <span><b>Eign</b> Eigenschaften</span>
    <span><b>Elem</b> Elementar</span>
    <span><b>Form</b> Form</span>
    <span><b>Heil</b> Heilung</span>
    <span><b>Hell</b> Hellsicht</span>
    <span><b>Illu</b> Illusion</span>
    <span><b>Krft</b> Kraft</span>
    <span><b>Meta</b> Meta-Magie</span>
    <span><b>Objk</b> Objekt</span>
    <span><b>Scha</b> Schaden</span>
    <span><b>Tele</b> Telekinese</span>
    <span><b>Umwt</b> Umwelt</span>
    <span><b>Vers</b> Verständigung</span>
  </div>
</section>

<div class="grid cols-2" style="margin-top:var(--gap)">
  <!-- Rituale -->
  <section class="card">
    <h3 class="card-title">Stabzauber &amp; Rituale <span class="meta">Ritualkenntnis {{ held.talente.get('Andere Talente', [{}])[0].get('taw', '') }}</span></h3>
    <ul class="sf-list">
      {% for r in held.rituale.stabzauber %}
      <li><span class="ico">❖</span><span><span class="sf-name">{{ r.name }}</span><span class="sf-desc">{{ r.effekt }}</span></span></li>
      {% endfor %}
      {% for r in held.rituale.andere %}
      <li><span class="ico">❖</span><span><span class="sf-name">{{ r.name }}</span><span class="sf-desc">{{ r.effekt }}</span></span></li>
      {% endfor %}
    </ul>
  </section>

  <!-- Sonderfertigkeiten -->
  <section class="card">
    <h3 class="card-title">Sonderfertigkeiten</h3>
    {% if held.sf.magisch %}
    <h4 style="font-family:var(--display);font-size:10px;letter-spacing:.22em;color:var(--accent-magic);margin:0 0 8px;text-transform:uppercase">Magische SF</h4>
    <ul class="sf-list">
      {% for sf in held.sf.magisch %}
      <li><span class="ico">✦</span><span><span class="sf-name">{{ sf.name }}</span><span class="sf-desc">{{ sf.desc }}</span></span></li>
      {% endfor %}
    </ul>
    {% endif %}
    {% if held.sf.allgemein %}
    <h4 style="font-family:var(--display);font-size:10px;letter-spacing:.22em;color:var(--accent-gold);margin:18px 0 8px;text-transform:uppercase">Allgemeine SF</h4>
    <ul class="sf-list general">
      {% for sf in held.sf.allgemein %}
      <li><span class="ico">◈</span><span><span class="sf-name">{{ sf.name }}</span><span class="sf-desc">{{ sf.desc }}</span></span></li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
</div>

<!-- ============================================================
     SEITE 4 — AUSRÜSTUNG + KAMPAGNE + VORGESCHICHTE
     ============================================================ -->
<div class="sec-head"><h2>Ausrüstung &amp; Inventar</h2><span class="rule"></span></div>
<div class="grid cols-2">
  <section class="card">
    <h3 class="card-title">Waffen &amp; Kampf</h3>
    {% for w in held.ausruestung.waffen %}
    <div class="weapon-card">
      <div class="w-name">{{ w.name }}</div>
      <div class="weapon-grid">
        <div><span class="k">DK</span><span class="v">{{ w.dk }}</span></div>
        <div><span class="k">TP</span><span class="v">{{ w.tp }}</span></div>
        <div><span class="k">AT</span><span class="v">{{ w.at }}</span></div>
        <div><span class="k">PA</span><span class="v">{{ w.pa if w.pa else '—' }}</span></div>
        <div><span class="k">INI</span><span class="v">{{ w.ini if w.ini else '+0' }}</span></div>
        <div><span class="k">BF</span><span class="v">{{ w.bf if w.bf else '—' }}</span></div>
      </div>
    </div>
    {% endfor %}
    <h4 style="font-family:var(--display);font-size:10px;letter-spacing:.22em;color:var(--accent-gold);margin:14px 0 8px;text-transform:uppercase">Finanzen</h4>
    <div class="equip-stat"><span class="k">Schulden</span><span class="v">{% for n in held.vor_nachteile.nachteile %}{% if 'Schulden' in n.name %}{{ n.stufe }}{% endif %}{% endfor %}</span></div>
    {% if held.ausruestung.geld %}<div class="equip-stat"><span class="k">Bargeld</span><span class="v">{{ held.ausruestung.geld }}</span></div>{% endif %}
  </section>

  <section class="card">
    <h3 class="card-title">Inventar</h3>
    {% if held.ausruestung.inventar %}
    <ul class="inv-list">
      {% for item in held.ausruestung.inventar %}
      <li>{{ item.name }}<span class="qty">{{ item.anzahl }}</span></li>
      {% endfor %}
    </ul>
    {% endif %}
    {% if held.ausruestung.reise %}
    <h4 style="font-family:var(--display);font-size:10px;letter-spacing:.22em;color:var(--accent-cold);margin:14px 0 8px;text-transform:uppercase">Reiseausrüstung</h4>
    <ul class="inv-list">
      {% for item in held.ausruestung.reise %}
      <li>{{ item.name }}<span class="qty">{{ item.menge }}</span></li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>
</div>

<!-- Kampagne + Steigerungs-Log -->
<div class="sec-head"><h2>Kampagne · Steigerung</h2><span class="rule"></span></div>
<div class="grid cols-2">
  <section class="card">
    <h3 class="card-title">Aktive Kampagne</h3>
    <div class="campaign">
      <div class="c-head">
        <h3>{{ kampagne.name }}</h3>
        {% if kampagne.status_icon %}
        <span class="status"><span class="dot-s"></span> {{ kampagne.status_text }}</span>
        {% endif %}
      </div>
      <div class="c-meta">
        <span><b>{{ kampagne.sessions | length }}</b> Sessions</span>
        <span><b>1</b> Held</span>
      </div>
    </div>
    {% if kampagne.sessions %}
    <table style="width:100%;border-collapse:collapse;margin-top:14px;font-size:12px;font-family:var(--subhead)">
      <thead><tr style="border-bottom:1px solid var(--rule)">
        <th style="text-align:left;padding:4px 0;font-family:var(--mono);font-size:9px;letter-spacing:.15em;color:var(--ink-mute)">#</th>
        <th style="text-align:left;padding:4px 8px;font-family:var(--mono);font-size:9px;letter-spacing:.15em;color:var(--ink-mute)">Datum</th>
        <th style="text-align:left;padding:4px 0;font-family:var(--mono);font-size:9px;letter-spacing:.15em;color:var(--ink-mute)">Inhalt</th>
      </tr></thead>
      <tbody>
      {% for s in kampagne.sessions %}
      <tr style="border-bottom:1px dotted var(--rule)">
        <td style="padding:5px 0;color:var(--ink-mute)">{{ s.nr }}</td>
        <td style="padding:5px 8px;font-family:var(--mono);font-size:11px;color:var(--ink-mute)">{{ s.datum }}</td>
        <td style="padding:5px 0;color:var(--ink)">{{ s.inhalt }}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p style="font-family:var(--mono);font-size:11px;color:var(--ink-dim);margin-top:12px">Noch keine Sessions gespielt.</p>
    {% endif %}
  </section>

  <section class="card">
    <h3 class="card-title">Steigerungs-Log <span class="meta">AP-Chronik</span></h3>
    <ul class="feed">
      {% for entry in held.steigerungslog %}
      <li>
        <span class="when">{{ entry.datum }}</span>
        <span class="what">{{ entry.aktion }}</span>
        {% if entry.begruendung %}<small style="font-family:var(--mono);color:var(--ink-dim);font-size:10px;letter-spacing:.05em">{{ entry.begruendung }}</small>{% endif %}
      </li>
      {% endfor %}
      {% if held._ap_bis_naechste_stufe %}
      <li>
        <span class="when">— in Aussicht</span>
        <span class="what">Stufe {{ held.meta.stufe + 1 }} bei {{ (held.meta.ap_gesamt + held._ap_bis_naechste_stufe) | format_ap }} AP gesamt</span>
        <small style="font-family:var(--mono);color:var(--ink-dim);font-size:10px;letter-spacing:.05em">noch {{ held._ap_bis_naechste_stufe }} AP bis Aufstieg</small>
      </li>
      {% endif %}
    </ul>
  </section>
</div>

<!-- Vorgeschichte -->
<div class="sec-head"><h2>Vorgeschichte</h2><span class="rule"></span></div>
<section class="card story">
  {% for para in held.vorgeschichte_paragraphs %}
  <p>{{ para }}</p>
  {% endfor %}
</section>

</div><!-- .codex -->

<button class="print-btn screen-only" onclick="window.print()">Kodex drucken</button>

<script>
/* Sortierung Zauber-Tabelle: Click auf ZfW-Header */
(function(){
  var spells = document.querySelectorAll('.spell:not(:first-child)');
  var container = spells[0] && spells[0].parentNode;
  var header = document.querySelector('.spell:first-child');
  if (!container || !header) return;
  var asc = false;
  header.style.cursor = 'pointer';
  header.title = 'Nach ZfW sortieren';
  header.addEventListener('click', function(){
    asc = !asc;
    var arr = Array.from(spells);
    arr.sort(function(a, b){
      var za = parseInt(a.querySelector('.zfw-num') && a.querySelector('.zfw-num').textContent) || 0;
      var zb = parseInt(b.querySelector('.zfw-num') && b.querySelector('.zfw-num').textContent) || 0;
      return asc ? za - zb : zb - za;
    });
    arr.forEach(function(el){ container.appendChild(el); });
  });
})();
</script>
</body>
</html>
